# ─── Database ─────────────────────────────────────────
# Supabase または ローカル PostgreSQL の接続文字列
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/clinicmark?schema=public"

# ─── NextAuth ──────────────────────────────────────────
# 本番環境では openssl rand -base64 32 で生成
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── Anthropic API ─────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ─── App ───────────────────────────────────────────────
APP_NAME="ClinicMark"
NODE_ENV="development"
