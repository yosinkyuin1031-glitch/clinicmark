# ─── Database ────────────────────────────────────────────────────
# Supabase または ローカル PostgreSQL の接続文字列
# ローカル開発: file:./dev.db（SQLite）でも動作します
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/clinicmark?schema=public"

# ─── NextAuth ────────────────────────────────────────────────────
# 本番環境では openssl rand -base64 32 で生成してください
NEXTAUTH_SECRET="your-secret-key-here"
# 本番: https://your-domain.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# ─── Anthropic API（必須）────────────────────────────────────────
# https://console.anthropic.com でキーを取得
# ※ 未設定の場合はモックモードで動作（生成ボタンはダミーデータを返す）
ANTHROPIC_API_KEY="sk-ant-..."

# ─── App ─────────────────────────────────────────────────────────
APP_NAME="ClinicMark"
NODE_ENV="development"
# QR コード生成・絶対URLが必要な箇所で使用
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ─── Threads 連携（任意）────────────────────────────────────────
# Meta for Developers でアプリを作成して取得
# https://developers.facebook.com/apps/
THREADS_APP_ID=""
THREADS_APP_SECRET=""

# ─── OpenAI（任意・音声文字起こし・画像リミックス）──────────────
# https://platform.openai.com でキーを取得
OPENAI_API_KEY=""

# ─── Google Gemini（任意・画像リミックス）────────────────────────
# https://aistudio.google.com でキーを取得
GEMINI_API_KEY=""

# ─── Vercel Cron（Threads予約投稿）─────────────────────────────
# openssl rand -base64 32 で生成し、Vercel ダッシュボードにも同じ値を設定
# Cron ハンドラー（/api/cron/threads-publish）の認証に使用
CRON_SECRET=""

# ─── Canva API（任意）───────────────────────────────────────────
# https://www.canva.com/developers/ でトークンを取得
CANVA_API_TOKEN=""
